# Copy this file to keystore.properties (DO NOT COMMIT keystore.properties)
# and update values for your release keystore.

# Absolute or project-relative path to your release keystore file.
storeFile=/absolute/path/to/arthamantri-release.jks

# Keystore password.
storePassword=CHANGE_ME

# Key alias inside the keystore.
keyAlias=arthamantri

# Key password for the alias.
keyPassword=CHANGE_ME
