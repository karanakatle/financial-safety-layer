<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#8A0F1A1F"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_card"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/overlayAlertTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="@string/overlay_tag"
            android:textColor="@color/badge_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlayAlertTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/alert_title_default"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlayAlertMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/alert_body_default"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/overlayPauseHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/overlayDismissBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_btn_primary"
            android:text="@string/alert_ack_short"
            android:textAllCaps="false"
            android:textColor="@color/btn_primary_text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/overlayUsefulBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_secondary"
                android:text="@string/alert_feedback_useful"
                android:textAllCaps="false"
                android:textColor="@color/btn_secondary_text" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/overlayNotUsefulBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_secondary"
                android:text="@string/alert_feedback_not_useful"
                android:textAllCaps="false"
                android:textColor="@color/btn_secondary_text" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
