<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlayScrim"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#8A0F1A1F"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/overlayAlertCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_card"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/overlayAlertTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="@string/overlay_tag"
            android:textColor="@color/badge_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlayAlertTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/alert_title_default"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlayAlertMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/alert_body_default"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/overlayWhyHeading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/alert_why_this_alert_label"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/overlayWhyBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/overlayNextActionHeading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/alert_next_safe_action_label"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/overlayNextActionBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/overlayGoalImpactHeading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/alert_essential_goal_impact_label"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/overlayGoalImpactBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/overlayPauseHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/overlayDismissBtn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_btn_primary"
            android:text="@string/alert_ack_short"
            android:textAllCaps="false"
            android:textColor="@color/btn_primary_text"
            android:textSize="17sp"
            android:textStyle="bold"
            android:backgroundTint="@null"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/overlayTrustedPersonBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_btn_secondary"
            android:text="@string/alert_action_trusted_person"
            android:textAllCaps="false"
            android:textColor="@color/btn_secondary_text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:backgroundTint="@null"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/overlaySupportBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_btn_secondary"
            android:text="@string/alert_action_support"
            android:textAllCaps="false"
            android:textColor="@color/btn_secondary_text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:backgroundTint="@null"
            app:backgroundTint="@null" />

        <TextView
            android:id="@+id/overlayUsefulnessHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/alert_feedback_optional_hint"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/overlayFeedbackRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/overlayUsefulBtn"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_secondary"
                android:text="@string/alert_feedback_useful"
                android:textAllCaps="false"
                android:textColor="@color/btn_secondary_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@null"
                app:backgroundTint="@null" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/overlayNotUsefulBtn"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_secondary"
                android:text="@string/alert_feedback_not_useful"
                android:textAllCaps="false"
                android:textColor="@color/btn_secondary_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@null"
                app:backgroundTint="@null" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/overlayProceedConfirmGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_help_steps"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/overlayProceedConfirmTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/alert_proceed_confirmation_title"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlayProceedConfirmBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/alert_proceed_confirmation_body"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/overlayConfirmProceedBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_btn_low_emphasis"
                android:text="@string/alert_proceed_confirmation_confirm"
                android:textAllCaps="false"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="@null"
                app:backgroundTint="@null" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
