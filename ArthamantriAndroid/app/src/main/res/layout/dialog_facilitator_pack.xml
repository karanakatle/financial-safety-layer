<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_help_dialog"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:id="@+id/facilitatorBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_facilitator_banner"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/facilitatorTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/facilitator_badge"
                android:textAllCaps="true"
                android:textColor="#D8F6F1"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorBannerHeadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/facilitator_banner_headline"
                android:textColor="@android:color/white"
                android:textSize="27sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/facilitator_subtitle"
                android:textColor="#E7F7F4"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/facilitatorPillRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <TextView
                android:id="@+id/facilitatorLanguagePill"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_status_pill_done"
                android:gravity="center"
                android:padding="10dp"
                android:textColor="@color/color_semantic_safe_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorConsentPill"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:layout_weight="1"
                android:background="@drawable/bg_status_pill_pending"
                android:gravity="center"
                android:padding="10dp"
                android:textColor="@color/color_semantic_warning_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorPermissionsPill"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_status_pill_pending"
                android:gravity="center"
                android:padding="10dp"
                android:textColor="@color/color_semantic_warning_text"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/facilitatorSupportContextCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_facilitator_step"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/facilitatorSupportContextBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="@string/help_support_context_badge"
                android:textColor="@color/badge_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorSupportContextTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorSupportContextBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/facilitatorSupportWhyHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/alert_why_this_alert_label"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/facilitatorSupportWhyBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/facilitatorSupportNextHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/alert_next_safe_action_label"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/facilitatorSupportNextBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/facilitatorSupportGoalHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/alert_essential_goal_impact_label"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/facilitatorSupportGoalBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/facilitatorSupportHelperHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_help_steps"
                android:padding="10dp"
                android:text="@string/facilitator_support_helper_hint"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_facilitator_step"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/facilitatorReadinessLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/facilitator_readiness_title"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorReadinessStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_help_steps"
                android:padding="10dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/facilitatorNextActionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/facilitator_next_action_title"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorNextActionValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_help_steps"
                android:padding="10dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/facilitatorStepsSectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_badge"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="@string/facilitator_steps_section_title"
            android:textColor="@color/badge_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_facilitator_step"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/facilitatorStepLanguageLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/facilitator_step_language"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorStepLanguageStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/facilitatorLanguageButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_btn_step"
                android:backgroundTint="@null"
                android:elevation="1dp"
                android:text="@string/facilitator_action_select_language"
                android:textAllCaps="false"
                android:textColor="@color/btn_step_text"
                app:backgroundTint="@null" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_facilitator_step"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/facilitatorStepConsentLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/facilitator_step_consent"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorStepConsentStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/facilitatorConsentButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_btn_step"
                android:backgroundTint="@null"
                android:elevation="1dp"
                android:text="@string/facilitator_action_record_consent"
                android:textAllCaps="false"
                android:textColor="@color/btn_step_text"
                app:backgroundTint="@null" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_facilitator_step"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/facilitatorStepPermissionsLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/facilitator_step_permissions"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorStepPermissionsStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/facilitatorPermissionsButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_btn_step"
                android:backgroundTint="@null"
                android:elevation="1dp"
                android:text="@string/facilitator_action_permissions"
                android:textAllCaps="false"
                android:textColor="@color/btn_step_text"
                app:backgroundTint="@null" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_facilitator_step"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/facilitatorStepMoneySetupLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/facilitator_step_money_setup"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorStepMoneySetupStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/facilitatorMoneySetupButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_btn_step"
                android:backgroundTint="@null"
                android:elevation="1dp"
                android:text="@string/facilitator_action_money_setup"
                android:textAllCaps="false"
                android:textColor="@color/btn_step_text"
                app:backgroundTint="@null" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_facilitator_step"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/facilitatorStepMonitoringLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/facilitator_step_monitoring"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorStepMonitoringStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/facilitatorStartMonitoringButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_btn_primary"
                android:backgroundTint="@null"
                android:elevation="2dp"
                android:text="@string/facilitator_action_start_monitor"
                android:textAllCaps="false"
                android:textColor="@color/btn_primary_text"
                app:backgroundTint="@null" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_facilitator_step"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/facilitatorTrustScriptTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="@string/facilitator_script_section_title"
                android:textColor="@color/badge_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorTrustScriptLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/facilitator_script_title"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/facilitatorTrustScriptBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_help_steps"
                android:padding="10dp"
                android:text="@string/facilitator_script_body"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/facilitatorRefreshButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_btn_secondary"
                android:backgroundTint="@null"
                android:elevation="1dp"
                android:text="@string/facilitator_action_refresh"
                android:textAllCaps="false"
                android:textColor="@color/btn_secondary_text"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/facilitatorCloseButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_btn_secondary"
                android:backgroundTint="@null"
                android:elevation="1dp"
                android:text="@string/help_close"
                android:textAllCaps="false"
                android:textColor="@color/btn_secondary_text"
                app:backgroundTint="@null" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
