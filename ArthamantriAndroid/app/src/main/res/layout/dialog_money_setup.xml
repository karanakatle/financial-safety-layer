<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_facilitator_step"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/moneySetupCohortLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/money_setup_cohort_label"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/moneySetupCohortSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_help_spinner"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_facilitator_step"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/moneySetupGoalOneLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/money_setup_goal1_label"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/moneySetupGoalOneSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_help_spinner"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_facilitator_step"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/moneySetupGoalTwoLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/money_setup_goal2_label"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/moneySetupGoalTwoSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_help_spinner"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
