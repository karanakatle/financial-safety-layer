<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_help_dialog"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/helpDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/helpDialogSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/help_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/helpDialogSteps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_help_steps"
        android:lineSpacingExtra="7dp"
        android:padding="12dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/helpLanguageLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/help_change_language"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/helpLanguageSpinner"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_help_spinner"
        android:paddingStart="10dp"
        android:paddingEnd="10dp" />

    <Button
        android:id="@+id/helpMoneySetupButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_btn_primary"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:text="@string/help_edit_money_setup"
        android:textAllCaps="false"
        android:textColor="@color/btn_primary_text"
        android:textStyle="bold" />

    <Button
        android:id="@+id/helpFacilitatorPackButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_btn_primary"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:text="@string/help_open_facilitator_pack"
        android:textAllCaps="false"
        android:textColor="@color/btn_primary_text"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/helpCloseButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_help_btn_ghost"
            android:contentDescription="@string/help_close"
            android:padding="10dp"
            android:src="@drawable/ic_dialog_close"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/helpApplyButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_help_btn_primary"
            android:contentDescription="@string/help_apply_language"
            android:padding="10dp"
            android:src="@drawable/ic_dialog_check"
            android:tint="@color/btn_primary_text" />
    </LinearLayout>

</LinearLayout>
