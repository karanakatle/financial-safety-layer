<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_help_dialog"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/permissionDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_perm_title"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/permissionDialogSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/dialog_perm_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/permissionDialogBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_help_steps"
        android:lineSpacingExtra="7dp"
        android:padding="12dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/permissionDialogActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/permissionDialogPrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_primary"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="@string/perm_continue"
            android:textAllCaps="false"
            android:textColor="@color/btn_primary_text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/permissionDialogSecondaryButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_btn_language_exit"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="@string/consent_exit"
            android:textAllCaps="false"
            android:textColor="@color/btn_secondary_text"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
