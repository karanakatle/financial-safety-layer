<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/btn_primary_ripple">

    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@android:color/white" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/gov_primary"
                android:startColor="@color/gov_primary_dark" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="@color/btn_primary_stroke" />
        </shape>
    </item>
</ripple>
